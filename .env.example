# ============================================================
# 业法协同系统 — 环境变量配置（示例文件）
# 复制此文件为 .env 并填入真实值
# .env 已在 .gitignore 中排除，请勿提交到 Git 仓库
# ============================================================

# Flask 密钥（生产环境请更换为随机字符串）
LEGAL_SECRET_KEY=your-secret-key-here

# ---------- 大模型配置（OpenAI 兼容协议）----------
# 支持豆包 Ark / OpenAI / 公司私有部署等任意兼容服务
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
LLM_MODEL=ark-code-latest
LLM_TIMEOUT=60
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024

# 无大模型时的知识库相似度阈值（TF-IDF 余弦相似度，0~1）
# 低于此阈值时不推荐知识库，直接引导用户提交法务
KB_SIMILARITY_THRESHOLD=0.25